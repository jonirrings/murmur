# ─── Murmur 环境变量参考 ───────────────────────────────────────────
# 本地开发：复制此文件为 .dev.vars 并填入实际值
# 生产环境：使用 `wrangler secret put <KEY>` 或 Cloudflare Dashboard 设置
# ────────────────────────────────────────────────────────────────────

# ── 必需（Auth）─────────────────────────────────────────────────────
# Auth 加密密钥（生产环境务必使用强随机字符串：openssl rand -hex 32）
BETTER_AUTH_SECRET=dev-secret-change-in-production-abc123xyz

# Auth 回调 URL
# 本地开发：http://localhost:8787
# 生产环境：https://your-domain.com
BETTER_AUTH_URL=http://localhost:8787

# ── 必需（Passkey / WebAuthn）───────────────────────────────────────
# Relying Party ID
# 本地开发：localhost
# 生产环境：你的域名（如 mm.o0x0o.com）
RP_ID=localhost

# 站点完整 URL（Passkey origin 验证用）
# 本地开发：http://localhost:8787
# 生产环境：https://your-domain.com
ORIGIN=http://localhost:8787

# ── 可选（Cloudflare Turnstile 人机验证）────────────────────────────
# 前端 Site Key（Dashboard → Turnstile → 创建站点获取）
# 本地开发可留空（跳过验证）
TURNSTILE_SITE_KEY=

# 服务端 Secret Key（Dashboard → Turnstile → 获取）
# 本地开发可留空
TURNSTILE_SECRET_KEY=

# ── 可选（Resend 邮件服务）─────────────────────────────────────────
# Magic Link 登录需要邮件发送能力
# 获取 API Key：https://resend.com/signup → 创建 API Key
# 本地开发可留空（Magic Link 将打印到控制台）
RESEND_API_KEY=
# 发件人地址（需在 Resend 中验证的域名邮箱，如 noreply@your-domain.com）
RESEND_FROM_EMAIL=

# ── 可选（GitHub OAuth 登录）─────────────────────────────────────────
# GitHub OAuth App 的 Client ID 和 Client Secret
# 获取方式：GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
# 回调 URL 填写：https://your-domain.com/api/auth/callback/github
# 本地开发可留空（不显示 GitHub 登录按钮）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
