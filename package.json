{
  "name": "murmur",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "vp build",
    "build:worker": "wrangler deploy --dry-run --outdir=dist/worker",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply murmur-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply murmur-db --remote",
    "db:studio": "drizzle-kit studio",
    "lint": "vp lint src/",
    "lint:fix": "vp lint src/ --fix",
    "fmt": "vp fmt src/ --write",
    "fmt:check": "vp fmt src/ --check",
    "typecheck": "tsc --noEmit",
    "test": "vp test run",
    "test:watch": "vp test",
    "prepare": "vp config"
  },
